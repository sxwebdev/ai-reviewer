{{define "title"}}{{.MR.Title}} · ai-reviewer{{end}}
{{define "content"}}
<div class="page-head">
  <div class="grow">
    <h1>{{.MR.Title}}</h1>
    <p class="cell-sub">{{.ProjectPath}} · !{{.MR.IID}} · {{.MR.SourceBranch}} → {{.MR.TargetBranch}} · <span class="mono">head {{shortSHA .MR.HeadSHA}}</span>{{if gt .MR.CreatedAt 0}} · opened {{fmtTime .MR.CreatedAt}} ({{ago .MR.CreatedAt}} ago){{end}}</p>
  </div>
  <a class="btn" href="{{.MR.WebURL}}" target="_blank" rel="noreferrer">Open in GitLab ↗</a>
</div>

<div class="card" x-data="{ open: false }">
  <form method="post" action="/mr/{{.MR.ID}}/review">
    <div class="row">
      <button class="btn btn--primary" {{if .Running}}disabled{{end}}>{{if .Running}}Review running…{{else}}Run review{{end}}</button>
      <button class="btn btn--ghost btn--sm" type="button" @click="open = !open" :aria-expanded="open">
        <span x-text="open ? 'Hide context & skills' : 'Add context & skills'"></span>
      </button>
      <span class="muted small">Runs locally against the current head. Nothing is posted to GitLab until you publish.</span>
    </div>

    <div x-show="open" x-cloak class="run-extra">
      <label class="label" for="run-context">Extra context for this review (optional)</label>
      <textarea class="textarea" id="run-context" name="context" rows="4"
                placeholder="Anything the reviewer should weigh: intent, risky areas, conventions, what to focus on…"></textarea>
      <label class="check"><input type="checkbox" name="remember"> Remember this context for future reviews of this project</label>

      {{if .AvailableSkills}}
      <fieldset class="run-skills" {{if not .AgentMode}}disabled{{end}}>
        <legend class="label">Skills to apply</legend>
        {{if not .AgentMode}}
        <p class="hint">⚠ Skills need agentic mode. Turn on <strong>Agentic</strong> in the header, then reload this page.</p>
        {{end}}
        {{range .AvailableSkills}}
        <label class="check skill-opt" title="{{.Description}}">
          <input type="checkbox" name="skills" value="{{.Name}}">
          <span class="mono">{{.Name}}</span>{{if .Description}} <span class="muted small">— {{.Description}}</span>{{end}}
        </label>
        {{end}}
      </fieldset>
      {{end}}
    </div>
  </form>
</div>

<div class="review-workspace">
  <div class="col-left">{{template "review-section" .}}</div>
  <aside class="diff-pane" aria-label="Diff">{{template "diff-pane" .Diff}}</aside>
</div>

{{if .PastReviews}}
<div class="card">
  <div class="panel-head"><h3 class="grow">Previous reviews</h3></div>
  <table class="table table--rows table--stack">
    <thead><tr><th>When</th><th>Head</th><th>Risk</th><th class="num">Findings</th><th></th></tr></thead>
    <tbody>
    {{range .PastReviews}}
    <tr>
      <td data-label="When" class="cell-sub nowrap">{{.When}}</td>
      <td data-label="Head" class="mono muted">{{shortSHA .HeadSHA}}</td>
      <td data-label="Risk">{{if .RiskLevel}}<span class="badge risk-{{.RiskLevel}}">{{.RiskLevel}}</span>{{else}}<span class="muted">—</span>{{end}}</td>
      <td data-label="Findings" class="num muted">{{.Findings}}</td>
      <td data-label=""><a class="btn btn--sm" href="/mr/{{$.MR.ID}}?review={{.ID}}">View</a></td>
    </tr>
    {{end}}
    </tbody>
  </table>
</div>
{{end}}
{{end}}

{{define "review-section"}}
<section id="review-section" aria-busy="{{if .Running}}true{{else}}false{{end}}"
  {{if .Running}}hx-get="/mr/{{.MR.ID}}/review-section" hx-trigger="every 3s" hx-target="#review-section" hx-swap="outerHTML"{{end}}>
  <p class="sr-only" aria-live="polite">{{if .Running}}Review in progress{{else if .Review}}Review complete: {{.FindingCount}} findings, risk {{.Review.RiskLevel}}{{end}}</p>

  {{if .ActionError}}<div class="alert alert--danger" role="alert"><div class="alert__body">{{.ActionError}}</div></div>{{end}}
  {{if .Historical}}<div class="alert alert--warn"><div class="alert__body">Viewing an earlier review (head {{shortSHA .Review.HeadSHA}}). <a href="/mr/{{.MR.ID}}">View the latest review →</a></div></div>{{end}}

  {{if .Running}}
  <div class="card" role="status">
    <div class="row"><span class="spinner" aria-hidden="true"></span> <strong>Reviewing…</strong>{{if .Progress}} <span class="muted">{{.Progress}}</span>{{end}}</div>
    <p class="muted small" style="margin:0">This panel updates on its own.</p>
  </div>
  {{else if and (eq .JobStatus "failed") (not .Review)}}
  <div class="card">
    <div class="row"><span class="badge st-failed">review failed</span></div>
    <pre class="err-box">{{.JobError}}</pre>
    <form method="post" action="/mr/{{.MR.ID}}/review"><button class="btn">Retry review</button></form>
  </div>
  {{end}}

  {{if and .Review (not .Running)}}
  <div class="card">
    <div class="review-head">
      <span class="badge risk-{{.Review.RiskLevel}}">risk: {{.Review.RiskLevel}}</span>
      {{if .Risk}}<span class="badge risk-{{.Risk.Level}}" title="deterministic score from git history and diff stats">computed: {{.Risk.Score}}/100</span>{{end}}
      <span class="badge">{{.Review.OverallRecommendation}}</span>
      {{if .CostLabel}}<span class="muted small">{{.CostLabel}}</span>{{end}}
      {{if .DurationLabel}}<span class="muted small" title="wall-clock time this review took">⏱ {{.DurationLabel}}</span>{{end}}
      {{if .Review.LLMModel}}<span class="muted small mono">{{.Review.LLMModel}}</span>{{end}}
      {{range .UsedSkills}}<span class="badge badge--pass" title="skill used in this review">/{{.}}</span>{{end}}
      <span class="grow"></span>
      {{if not .Historical}}
        {{if gt .ProposedCount 0}}<form method="post" action="/review/{{.Review.ID}}/approve-all"><button class="btn">Approve all ({{.ProposedCount}})</button></form>{{end}}
        {{if gt .ApprovedCount 0}}<form method="post" action="/review/{{.Review.ID}}/drafts"><button class="btn btn--primary">Create draft notes ({{.ApprovedCount}})</button></form>{{end}}
      {{end}}
    </div>
    {{if .Review.Summary}}<p class="summary">{{.Review.Summary}}</p>{{end}}

    {{if .Completeness}}
    <div class="report-block">
      <h4 class="report-head">Task completeness (stated intent vs. diff)</h4>
      {{if .Completeness.Note}}<p class="muted small">{{.Completeness.Note}}</p>{{end}}
      {{range .Completeness.Criteria}}
      <div class="criterion">
        <span class="badge crit-{{.Status}}">{{.Status}}</span>
        <span class="criterion-text">{{.Criterion}}</span>
        {{if .Evidence}}<span class="muted small">— {{.Evidence}}</span>{{end}}
      </div>
      {{end}}
    </div>
    {{end}}

    {{if .Risk}}
    <details class="report-details">
      <summary class="muted small">computed risk {{.Risk.Score}}/100 ({{.Risk.Level}}) — {{len .Risk.Factors}} factors</summary>
      <table class="pass-table">
        <thead><tr><th>factor</th><th>points</th><th>detail</th></tr></thead>
        <tbody>
        {{range .Risk.Factors}}<tr><td class="mono">{{.Name}}</td><td>{{printf "%.0f" .Weight}}</td><td>{{.Detail}}</td></tr>{{end}}
        </tbody>
      </table>
    </details>
    {{end}}

    {{if .Coverage}}
    <details class="report-details">
      <summary class="muted small">{{if gt .Coverage.TotalAdded 0}}changed-line coverage: {{printf "%.0f" .Coverage.Pct}}% ({{.Coverage.TotalCovered}}/{{.Coverage.TotalAdded}} added lines){{else}}changed-line coverage: not measured{{end}}</summary>
      <table class="pass-table">
        <thead><tr><th>file</th><th>covered</th><th>uncovered added lines</th></tr></thead>
        <tbody>
        {{range .Coverage.Files}}<tr><td class="mono">{{.Path}}</td><td>{{.Covered}}/{{.Added}}</td><td class="mono">{{range $i, $l := .Uncovered}}{{if $i}}, {{end}}{{$l}}{{end}}</td></tr>{{end}}
        </tbody>
      </table>
      {{range .Coverage.Skipped}}<div class="muted small">not measured: {{.Root}} — {{.Reason}}</div>{{end}}
      {{range .Coverage.Notes}}<div class="muted small">note: {{.}}</div>{{end}}
    </details>
    {{end}}

    {{if .PassReports}}
    <details class="pass-reports">
      <summary class="muted small">pipeline: {{len .PassReports}} passes</summary>
      <table class="pass-table">
        <thead><tr><th>pass</th><th>findings</th><th>cost</th><th>time</th><th></th></tr></thead>
        <tbody>
        {{range .PassReports}}
        <tr>
          <td class="mono">{{.Name}}</td>
          <td>{{.RawFindings}}</td>
          <td>{{.CostLabel}}</td>
          <td>{{.DurationLabel}}</td>
          <td>{{if .Err}}<span class="badge st-failed" title="{{.Err}}">failed</span>{{end}}</td>
        </tr>
        {{end}}
        </tbody>
      </table>
    </details>
    {{end}}

    {{if not .Groups}}<p class="muted">No findings.</p>{{end}}
    {{range .Groups}}
    <h4 class="sev-group-head sev-{{.Severity}}">{{.Severity}} <span class="count">· {{len .Items}}</span></h4>
    {{range .Items}}
    <div class="finding sev-l-{{.Severity}} st-{{.Status}}{{if gt .EditedAt 0}} is-edited{{end}}" x-data="{ edit: false }" data-finding="{{.ID}}">
      <div class="finding-head">
        <span class="badge sev-{{.Severity}}">{{.Severity}}</span>
        <span class="badge badge--cat">{{.Category}}</span>
        {{if and .Pass (ne .Pass "general")}}<span class="badge badge--pass" title="found by the {{.Pass}} specialist pass">{{.Pass}}</span>{{end}}
        {{if .Verification}}<span class="badge ver-{{.Verification}}" title="skeptic verification outcome">{{.Verification}}</span>{{end}}
        <strong class="finding-title">{{.Title}}</strong>
        {{if gt .EditedAt 0}}<span class="badge st-edited">edited</span>{{end}}
        {{if .FilePath}}<a class="finding-loc" href="{{$.MR.WebURL}}/diffs" target="_blank" rel="noreferrer">{{.FilePath}}{{if .NewLine}}:{{.NewLine}}{{else if .OldLine}}:{{.OldLine}}{{end}}</a>{{end}}
      </div>
      <div class="finding-body" x-show="!edit">{{.Body}}</div>
      {{if .ValidationError}}<p class="hint">⚠ {{.ValidationError}}</p>{{end}}

      {{if not $.Historical}}
      <form x-show="edit" style="display:none" hx-post="/finding/{{.ID}}/edit" hx-target="#review-section" hx-swap="outerHTML" hx-disabled-elt="find button">
        <label class="sr-only" for="edit-{{.ID}}">Edit finding comment</label>
        <textarea class="textarea" id="edit-{{.ID}}" name="body" rows="6">{{.Body}}</textarea>
        <div class="finding-actions"><button class="btn" type="submit">Save</button><button class="btn btn--ghost" type="button" @click="edit=false">Cancel</button></div>
      </form>
      {{if eq .Status "proposed"}}
      <div class="finding-actions" x-show="!edit">
        <form hx-post="/finding/{{.ID}}/approve" hx-target="#review-section" hx-swap="outerHTML" hx-disabled-elt="find button">
          <button class="btn btn--good" data-approve>Approve</button>
        </form>
        <button class="btn btn--ghost" type="button" @click="edit=true">Edit</button>
        <form class="reject" hx-post="/finding/{{.ID}}/reject" hx-target="#review-section" hx-swap="outerHTML" hx-disabled-elt="find button">
          <label class="sr-only" for="reason-{{.ID}}">Rejection reason</label>
          <input class="input" id="reason-{{.ID}}" type="text" name="reason" placeholder="reason (optional)">
          <label class="check"><input type="checkbox" name="fp"> false-positive</label>
          <button class="btn btn--danger">Reject</button>
        </form>
      </div>
      {{else}}
      <div class="row wrap"><span class="badge st-{{.Status}}">{{.Status}}</span>{{if .RejectionReason}}<span class="muted small">— {{.RejectionReason}}</span>{{end}}</div>
      {{end}}
      {{else}}
      <div class="row"><span class="badge st-{{.Status}}">{{.Status}}</span></div>
      {{end}}
    </div>
    {{end}}
    {{end}}

    {{if and (not .Historical) (gt .DraftedCount 0)}}
    {{/* SAFETY: this UI gate is additive. The server independently re-checks the
         typed phrase against service.ConfirmPhrase in PublishService.PublishDrafts
         before any GitLab write — the :disabled binding is only a guardrail. */}}
    <section class="danger-zone" aria-labelledby="publish-h" x-data="{ typed: '' }">
      <div class="danger-zone__head">
        <span class="badge badge--bad">Publish to GitLab</span>
        <h3 id="publish-h" class="danger-zone__title">Post {{.DraftedCount}} approved comment{{if ne .DraftedCount 1}}s{{end}}</h3>
      </div>
      <p class="danger-zone__copy">This publishes your {{.DraftedCount}} approved draft note{{if ne .DraftedCount 1}}s{{end}} to the merge request on GitLab, where the author will see {{if eq .DraftedCount 1}}it{{else}}them{{end}}. Rejected and unreviewed findings stay local. Nothing is posted automatically — this is the only action that writes to GitLab.</p>
      <form class="danger-zone__form" method="post" action="/review/{{.Review.ID}}/publish">
        <div class="field">
          <label class="label" for="publish-confirm">Type <code>{{.PublishPhrase}}</code> to confirm</label>
          <input class="input input--mono" id="publish-confirm" name="confirm" x-model="typed"
                 autocomplete="off" autocapitalize="off" spellcheck="false" aria-describedby="publish-hint" placeholder="{{.PublishPhrase}}">
          <p class="hint" id="publish-hint">Case-sensitive; the count must match.</p>
        </div>
        <button class="btn btn--danger-solid" type="submit" disabled
                :disabled="typed !== '{{.PublishPhrase}}'" :aria-disabled="typed !== '{{.PublishPhrase}}'">
          Publish {{.DraftedCount}} comment{{if ne .DraftedCount 1}}s{{end}}
        </button>
      </form>
    </section>
    {{end}}
  </div>
  {{else if not .Running}}
  <div class="empty">
    <p class="empty__title">No review yet</p>
    <p class="empty__hint">Run a review to analyze this MR locally. Nothing is posted to GitLab until you publish.</p>
  </div>
  {{end}}
</section>
{{end}}

{{define "diff-pane"}}
<div id="diff-pane">
  {{if not .Captured}}
  <div class="diff-pane-empty">Diff not captured for this head yet. Run a review to store it, then it appears here with findings pinned inline.</div>
  {{else}}
    {{if .Unanchored}}
    <div class="diff-unanchored">
      <strong>Not anchored to a diff line</strong>
      <p class="small" style="margin:.25rem 0 0">These map to an overview note rather than one line:</p>
      {{range .Unanchored}}<div class="small">· <span class="badge sev-{{.Severity}}">{{.Severity}}</span> {{.Title}} <span class="mono muted">{{.FilePath}}</span></div>{{end}}
    </div>
    {{end}}
    {{range .Files}}{{template "diff-file" .}}{{end}}
  {{end}}
</div>
{{end}}

{{define "diff-file"}}
<details class="diff-file"{{if .Expanded}} open{{end}}>
  <summary class="diff-file__head">
    <span class="diff-file__path">{{.DisplayPath}}</span>
    <span class="badge badge--cat">{{.Kind}}</span>
    {{if gt .FindingCount 0}}<span class="badge badge--info" title="findings in this file">{{.FindingCount}}</span>{{end}}
  </summary>
  {{if .IsBinary}}
  <div class="diff-binary">Binary file — no preview.</div>
  {{else}}
    {{range .Hunks}}
    <div class="diff-hunk-head">{{.Header}}</div>
    {{range .Lines}}
    <div class="diff-line is-{{.Kind}}{{if .Findings}} is-pinned{{end}}">
      <span class="ln">{{.OldLine}}</span>
      <span class="ln">{{.NewLine}}</span>
      <span class="mark" aria-hidden="true"></span>
      <span class="code">{{.Content}}</span>
      {{range .Findings}}
      <div class="diff-pin"><span class="diff-pin__title">[{{.Severity}}] {{.Title}}</span><span>{{.Body}}</span></div>
      {{end}}
    </div>
    {{end}}
    {{end}}
  {{end}}
</details>
{{end}}
